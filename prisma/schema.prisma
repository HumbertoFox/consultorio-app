datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model addresss {
  address_id      Int        @id @default(autoincrement())
  zipcode         String
  residencenumber String     @db.VarChar(50)
  building        String     @db.VarChar(100)
  buildingblock   String     @db.VarChar(50)
  apartment       String     @db.VarChar(50)
  registerdate    DateTime   @default(now()) @db.Timestamp(0)
  zipcodes        zipcodes   @relation(fields: [zipcode], references: [zipcode])
  doctors         doctors[]
  patients        patients[]
  users           users[]
}

model consultations {
  consultation_id  Int      @id @default(autoincrement())
  cpf              String
  crm              String
  plan             String   @db.VarChar(50)
  particular       String   @db.VarChar(50)
  courtesy         String   @db.VarChar(20)
  observation      String
  consultdatestart String
  consultdateend   String
  patient_id       Int
  user_id          Int
  registerdate     DateTime @default(now()) @db.Timestamp(0)
  cpfs             cpfs     @relation(fields: [cpf], references: [cpf])
  crms             crms     @relation(fields: [crm], references: [crm])
  patients         patients @relation(fields: [patient_id], references: [patient_id])
  users            users    @relation(fields: [user_id], references: [user_id])
}

model cpfs {
  cpf           String          @id @db.VarChar(11)
  name          String          @db.VarChar(100)
  dateofbirth   String
  consultations consultations[]
  doctors       doctors[]
  patients      patients[]
  users         users[]
}

model crms {
  crm           String          @id @db.VarChar(11)
  consultations consultations[]
  doctors       doctors[]
}

model doctors {
  doctor_id    Int        @id @default(autoincrement())
  crm          String
  cpf          String
  telephone    String
  address_id   Int
  user_id      Int
  registerdate DateTime   @default(now()) @db.Timestamp(0)
  addresss     addresss   @relation(fields: [address_id], references: [address_id])
  cpfs         cpfs       @relation(fields: [cpf], references: [cpf])
  crms         crms       @relation(fields: [crm], references: [crm])
  telephones   telephones @relation(fields: [telephone], references: [telephone])
  users        users      @relation(fields: [user_id], references: [user_id])
}

model patients {
  patient_id    Int             @id @default(autoincrement())
  cpf           String
  telephone     String
  address_id    Int
  registerdate  DateTime        @default(now()) @db.Timestamp(0)
  consultations consultations[]
  addresss      addresss        @relation(fields: [address_id], references: [address_id])
  cpfs          cpfs            @relation(fields: [cpf], references: [cpf])
  telephones    telephones      @relation(fields: [telephone], references: [telephone])
}

model telephones {
  telephone String     @id @db.VarChar(11)
  email     String     @db.VarChar(150)
  doctors   doctors[]
  patients  patients[]
  users     users[]
}

model users {
  user_id       Int             @id @default(autoincrement())
  cpf           String
  telephone     String
  password      String          @db.VarChar(200)
  address_id    Int
  registerdate  DateTime        @default(now()) @db.Timestamp(0)
  consultations consultations[]
  doctors       doctors[]
  addresss      addresss        @relation(fields: [address_id], references: [address_id])
  cpfs          cpfs            @relation(fields: [cpf], references: [cpf])
  telephones    telephones      @relation(fields: [telephone], references: [telephone])
}

model zipcodes {
  zipcode  String     @id @db.VarChar(11)
  street   String     @db.VarChar(100)
  district String     @db.VarChar(100)
  city     String     @db.VarChar(100)
  addresss addresss[]
}
